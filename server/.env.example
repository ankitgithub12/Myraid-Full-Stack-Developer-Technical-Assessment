PORT=5000
NODE_ENV=production
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
JWT_SECRET=<replace-with-a-long-random-secret>
ENCRYPTION_KEY=<32-character-secret-key>
# Set this to your deployed Render frontend URL (no trailing slash)
FRONTEND_URL=https://your-frontend-url.onrender.com

# SendGrid API Credentials
# Get your API key from SendGrid (https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The email address you verified as a sender in SendGrid
EMAIL_FROM=your-verified-sender@example.com
